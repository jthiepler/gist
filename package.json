{
  "name": "gist",
  "version": "0.1.3",
  "description": "Local-first therapy session tool",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check-version": "node scripts/version.mjs check",
    "set-version": "node scripts/version.mjs set",
    "test": "node --test --experimental-strip-types tests/*.test.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "bash scripts/tauri.sh",
    "sidecar:build": "bash scripts/build-macos.sh --mode development",
    "sidecar:rebuild": "bash scripts/build-macos.sh --mode development --force",
    "tauri:app": "bash scripts/tauri.sh build --bundles app",
    "tauri:dmg": "bash scripts/tauri.sh build --bundles dmg",
    "tauri:bundle": "bash scripts/tauri.sh build --bundles app,dmg",
    "tauri:release": "bash scripts/release-macos.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
